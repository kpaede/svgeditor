{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "Node16",
    "target": "ES2017",
    "allowJs": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES2017"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
